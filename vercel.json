{
  "buildCommand": "npm run build --prefix frontend",
  "outputDirectory": "frontend/dist",
  "framework": "vite",
  "rewrites": [
    { "source": "/api/(.*)", "destination": "https://promptcraft-api-t7qu.onrender.com/api/$1" },
    { "source": "/((?!assets/|vite.svg|favicon.ico).*)", "destination": "/index.html" }
  ]
}
